<section
  class="account-page account-page-details"
  data-template-account>
  <header class="account-page-masthead">
    <h1 class="account-page-title">
      {{ 'customers.account.title' | t }}
    </h1>
  </header>

  <div class="account-page-content">
    <div class="account-page--two-column">
      {% comment %}
        Customer order summary
      {% endcomment %}
      <div class="account-page--column-large account-order-history">
        <h2 class="account-page-subtitle">
          {{ 'customers.account.order_history' | t }}
        </h2>

        {% if customer.orders.size > 0 %}
          {% paginate customer.orders by 20 %}
            <table class="account-table account-order-list">
              <thead>
                <tr>
                  <th>{{ 'customers.account.order' | t }}</th>
                  <th>{{ 'customers.account.payment' | t }}</th>
                  <th>{{ 'customers.account.fulfillment' | t }}</th>
                  <th>{{ 'customers.account.total' | t }}</th>
                  <th>Tracking</th>
                </tr>
              </thead>

              <tbody>
                {% for order in customer.orders %}
                  <tr>
                    <td class="account-order-number">
                      {%- capture order_link -%}
                        {{ order.name }} - {{ order.created_at | date: format: 'short_day_month_year' }}
                      {%- endcapture -%}

                      {{ order_link | strip_newlines | link_to: order.customer_url, order.name }}
                    </td>
                    <td class="payment-status--{{ order.financial_status }}">
                      {{ order.financial_status_label }}
                    </td>
                    <td class="fulfillment-status--{{ order.fulfillment_status }}">
                      {{ order.fulfillment_status_label }}
                    </td>
                    <td class="account-order-list-total">
                      <span class="money">{{ order.total_price | money }}</span>
                    </td>
                    <td class="account-order-tracking">
                      {% assign has_tracking = false %}
                      {% assign rendered_fulfillments = '' %}
                      {% for line_item in order.line_items %}
                        {% assign fulfillment = line_item.fulfillment %}
                        {% if fulfillment == blank %}
                          {% continue %}
                        {% endif %}

                        {% if rendered_fulfillments contains fulfillment.id %}
                          {% continue %}
                        {% endif %}
                        {% assign rendered_fulfillments = rendered_fulfillments | append: fulfillment.id | append: ',' %}

                        {% assign tracking_numbers = fulfillment.tracking_numbers %}
                        {% if tracking_numbers == blank and fulfillment.tracking_number %}
                          {% assign tracking_numbers = fulfillment.tracking_number | split: '||' %}
                        {% endif %}
                        {% assign tracking_urls = fulfillment.tracking_urls %}
                        {% if tracking_urls == blank and fulfillment.tracking_url %}
                          {% assign tracking_urls = fulfillment.tracking_url | split: '||' %}
                        {% endif %}

                        {% if tracking_numbers and tracking_numbers != blank %}
                          {% assign has_tracking = true %}
                          <div class="account-order-tracking-fulfillment">
                            <ul class="tracking-list">
                              {% for tracking_number in tracking_numbers %}
                                {% assign tracking_url = '' %}
                                {% if tracking_urls and tracking_urls.size > forloop.index0 %}
                                  {% assign tracking_url = tracking_urls[forloop.index0] %}
                                {% endif %}
                                <li class="tracking-list-item">
                                  {% if fulfillment.tracking_company %}
                                    <span class="tracking-company">{{ fulfillment.tracking_company }}</span>
                                  {% endif %}
                                  {% if tracking_url %}
                                    <a
                                      href="{{ tracking_url }}"
                                      class="tracking-number-link"
                                      target="_blank"
                                      rel="noopener noreferrer"
                                    >
                                      {{ tracking_number }}
                                    </a>
                                  {% else %}
                                    <span class="tracking-number">{{ tracking_number }}</span>
                                  {% endif %}
                                </li>
                              {% endfor %}
                            </ul>
                          </div>
                        {% endif %}
                      {% endfor %}
                      {% unless has_tracking %}
                        <span class="tracking-number-empty">Tracking not yet available</span>
                      {% endunless %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>

            {% render 'pagination', paginate: paginate %}
          {% endpaginate %}
        {% else %}
          <p class="empty">{{ 'customers.account.empty' | t }}</p>
        {% endif %}
      </div>

      {% comment %}
        Customer address summary
      {% endcomment %}
      <div class="account-page--column-small account-info">
        <div class="account-info-block">
          <h2 class="account-page-subtitle">
            {{ customer.name }}
          </h2>

          <p class="account-info-item">
            <a href="mailto:{{ customer.email }}">
              {{ customer.email }}
            </a>
          </p>
        </div>

        <div class="account-info-block">
          {% if customer.default_address != nil %}
            <h2 class="account-page-subtitle">
              {{ 'customers.account.default_address' | t }}
            </h2>

            {%
              render 'account-address-list',
              address: customer.default_address
            %}
          {% endif %}

          <p class="account-address-item">
            {% if customer.addresses_count == 0 %}
              <a href="{{ routes.account_addresses_url }}">
                {{ 'customers.account.new_address_link' | t }}
              </a>
            {% else %}
              <a href="{{ routes.account_addresses_url }}">
                {{ 'customers.account.view_addresses' | t: count: customer.addresses_count }}
              </a>
            {% endif %}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
